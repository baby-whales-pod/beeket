{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Beeket model server — request rate, latency, inference throughput, model lifecycle, and process health.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HTTP",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (pattern) (rate(beeket_http_requests_total[1m]))",
          "legendFormat": "{{pattern}}"
        }
      ],
      "title": "Request rate by endpoint (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (pattern, le) (rate(beeket_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{pattern}}"
        }
      ],
      "title": "HTTP latency p95 by endpoint",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (pattern) (rate(beeket_http_requests_total{status_code=~\"5..\"}[5m])) / sum by (pattern) (rate(beeket_http_requests_total[5m]))",
          "legendFormat": "{{pattern}}"
        }
      ],
      "title": "HTTP error ratio (5xx)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "title": "Models",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 18 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "expr": "beeket_models_loaded", "legendFormat": "loaded" }
      ],
      "title": "Loaded models",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 18 },
      "id": 5,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(beeket_model_load_duration_seconds_bucket[10m])))",
          "legendFormat": "p95 {{model}}"
        }
      ],
      "title": "Model load time p95",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 102,
      "title": "Inference",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (model, le) (rate(beeket_inference_tokens_per_second_bucket[5m])))",
          "legendFormat": "p50 {{model}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(beeket_inference_tokens_per_second_bucket[5m])))",
          "legendFormat": "p95 {{model}}"
        }
      ],
      "title": "Tokens/sec (p50 and p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 7,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(beeket_inference_time_to_first_token_seconds_bucket[5m])))",
          "legendFormat": "p95 TTFT {{model}}"
        }
      ],
      "title": "Time to first token p95",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 103,
      "title": "Process",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 36 },
      "id": 8,
      "targets": [
        { "expr": "process_resident_memory_bytes", "legendFormat": "RSS" }
      ],
      "title": "Process RSS",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 36 },
      "id": 9,
      "targets": [
        { "expr": "go_goroutines", "legendFormat": "goroutines" }
      ],
      "title": "Goroutines",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 36 },
      "id": 10,
      "targets": [
        { "expr": "beeket_uptime_seconds", "legendFormat": "uptime" }
      ],
      "title": "Uptime",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["beeket"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Beeket",
  "uid": "beeket-overview",
  "version": 1
}
